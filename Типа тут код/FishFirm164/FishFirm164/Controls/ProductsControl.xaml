<UserControl x:Class="FishFirm164.ProductsControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#2d2d2d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтрации -->
        <WrapPanel Margin="0,0,0,10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="White"/>
            <TextBox x:Name="txtSearch" Width="150" TextChanged="TxtSearch_TextChanged" 
                     Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>

            <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="15,0,5,0" Foreground="White"/>
            <ComboBox x:Name="cmbCategory" Width="120" 
                      SelectedValuePath="CategoryID"
                      SelectionChanged="CmbFilter_SelectionChanged" 
                      Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding CategoryName}" Foreground="White"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Производитель:" VerticalAlignment="Center" Margin="15,0,5,0" Foreground="White"/>
            <ComboBox x:Name="cmbManufacturer" Width="120" 
                      SelectedValuePath="ManufacturerID"
                      SelectionChanged="CmbFilter_SelectionChanged" 
                      Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" Foreground="White"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Button Content="Сбросить" Width="80" Margin="15,0" Click="BtnResetFilter_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </WrapPanel>

        <!-- Кнопки управления (видимость по роли) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="Добавить товар" Width="120" Margin="0,0,10,0" Click="BtnAdd_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
            <Button x:Name="btnEdit" Content="Изменить" Width="100" Margin="0,0,10,0" Click="BtnEdit_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Click="BtnDelete_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </StackPanel>

        <!-- Список товаров (плитки) -->
        <ListBox x:Name="lvProducts" Grid.Row="2" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="LvProducts_MouseDoubleClick"
                 Background="Transparent">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Width="320" Margin="10" Padding="10"
                            Background="#3d3d3d" CornerRadius="8" BorderBrush="#555" BorderThickness="1">
                        <StackPanel>
                            <Border Height="120" Background="#2d2d2d" CornerRadius="5" Margin="0,0,0,10">
                                <TextBlock Text="Нет фото" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#888"/>
                            </Border>
                            <TextBlock Text="{Binding ProductName}" FontWeight="Bold" FontSize="16" Foreground="White" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Categories.CategoryName}" Foreground="#aaa" Margin="0,5,0,0"/>
                            <TextBlock Text="{Binding Manufacturers.Name}" Foreground="#aaa"/>
                            <TextBlock Text="{Binding QuantityInStock, StringFormat='В наличии: {0} шт.'}" Margin="0,10,0,0" Foreground="#6a9fb5"/>
                            <TextBlock Text="{Binding RetailPrice, StringFormat='Цена: {0:C2}'}" FontWeight="Bold" FontSize="18" Foreground="#f0b27a" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Пагинация -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="&lt;" Width="30" Click="PrevPage_Click" 
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
            <TextBlock x:Name="txtPage" Text="1" VerticalAlignment="Center" Margin="5,0" Foreground="White"/>
            <Button Content="&gt;" Width="30" Click="NextPage_Click"
                    Background="#3d3d3d" Foreground="White" BorderBrush="#555" BorderThickness="1"/>
        </StackPanel>
    </Grid>
</UserControl>